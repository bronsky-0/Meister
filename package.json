{
  "name": "meister",
  "productName": "Meister",
  "version": "1.0.0",
  "description": "Meister — терминал секретаря и турнирное табло для HEMA",
  "main": "electron/main.js",
  "author": "Meister",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "server": "node sync-server.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.meister.app",
    "productName": "Meister",
    "artifactName": "Meister-Setup-${os}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "sync-server.js",
      "network-sync.js",
      "tournament-playoff.js",
      "display_screen.html",
      "meister-theme.css",
      "meister-tournaments.js",
      "secretary_terminal_updated .html",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Meister-Setup-win.${ext}"
    },
    "dmg": {
      "artifactName": "Meister-Setup-mac.${ext}"
    },
    "appImage": {
      "artifactName": "Meister-Setup-linux.${ext}"
    }
  }
}
