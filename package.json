{
  "name": "meister",
  "productName": "Meister",
  "version": "1.0.0",
  "description": "Meister — терминал секретаря и турнирное табло для HEMA",
  "main": "electron/main.js",
  "author": "Meister",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "server": "node sync-server.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --universal",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "test": "node tests/pool-rankings.test.js"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.meister.app",
    "productName": "Meister",
    "artifactName": "Meister-Setup-${os}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "sync-server.js",
      "network-sync.js",
      "tournament-playoff.js",
      "tournament-swiss.js",
      "display_screen.html",
      "meister-theme.css",
      "meister-tournaments.js",
      "pool-rankings-core.js",
      "secretary_terminal.html",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSHighResolutionCapable": true
      }
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Meister-Setup-win.${ext}"
    },
    "dmg": {
      "artifactName": "Meister-Setup-mac.${ext}",
      "title": "Meister ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 130, "y": 200, "type": "file" },
        { "x": 410, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "appImage": {
      "artifactName": "Meister-Setup-linux.${ext}"
    }
  }
}
